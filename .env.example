# # NEW FEATURE START - Environment Variables

# ─── Neon PostgreSQL (https://neon.tech) ─────────────────────────────────────
# Copy from your Neon dashboard → Connection Details → Connection string
DATABASE_URL="postgresql://USER:PASSWORD@ep-XXXX.us-east-2.aws.neon.tech/neondb?sslmode=require"

# ─── App Config ───────────────────────────────────────────────────────────────
VITE_API_BASE_URL="/api"

# ─── Admin Secret (change this!) ─────────────────────────────────────────────
ADMIN_SECRET="abbassa2024admin"

# ─── File Storage (optional: Cloudflare R2 / Supabase Storage) ───────────────
# STORAGE_BUCKET_URL="https://your-bucket.r2.cloudflarestorage.com"
# STORAGE_ACCESS_KEY=""
# STORAGE_SECRET_KEY=""

# ─── Chargily Pay V2 (Edahabia / CIB) ────────────────────────────────────────
# Get your keys at https://pay.chargily.com → Developers → API Keys
# Use the `test_sk_...` key in sandbox and `live_sk_...` once you go live.
# IMPORTANT: No spaces around `=`. Write CHARGILY_SECRET_KEY=test_sk_... (not
# CHARGILY_SECRET_KEY = test_sk_...). The leading space in the value will
# cause Chargily to respond with "Unauthenticated".
CHARGILY_SECRET_KEY=test_sk_XXXXXXXXXXXXXXXXXXXXXXXX
# Public site URL (used to build success/failure + webhook redirect URLs).
# This MUST match the site the user is browsing or Chargily's redirect will
# break out of the current deployment/preview.
NEXT_PUBLIC_SITE_URL=http://localhost:3000
# Optional: override the Chargily API base URL (defaults to https://pay.chargily.net/api/v2)
# CHARGILY_API_URL="https://pay.chargily.net/api/v2"

# # NEW FEATURE END - Environment Variables

# ─── Instructions ─────────────────────────────────────────────────────────────
# 1. Create a free Neon account at https://neon.tech
# 2. Create a new project → copy the connection string above
# 3. Run: npx prisma migrate dev --name init
# 4. Run: npx prisma generate
# 5. Start your dev server
