generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum OrderStatus {
  pending
  in_progress
  completed
  delivered
}

enum InvoiceStatus {
  draft
  sent
  paid
  overdue
  cancelled
}

enum SubscriptionStatus {
  active
  paused
  cancelled
  expired
}

model Order {
  id           String      @id @default(cuid())
  plan         String
  amount       String
  authorName   String
  bookTitle    String
  genre        String      @default("")
  email        String
  synopsis     String      @default("")
  instructions String      @default("")
  status       OrderStatus @default(pending)
  adminNotes   String      @default("")
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt

  files        OrderFile[] @relation("ClientOrderFiles")
  deliverables OrderFile[] @relation("AdminOrderFiles")
  messages     Message[]
  logs         EventLog[]
  invoices     Invoice[]
}

model OrderFile {
  id            String   @id @default(cuid())
  filename      String
  storedAs      String
  size          Int
  mimeType      String
  uploadedBy    String
  createdAt     DateTime @default(now())
  clientOrderId String?
  adminOrderId  String?

  clientOrder Order? @relation("ClientOrderFiles", fields: [clientOrderId], references: [id], onDelete: Cascade)
  adminOrder  Order? @relation("AdminOrderFiles", fields: [adminOrderId], references: [id], onDelete: Cascade)
}

model Message {
  id        String    @id @default(cuid())
  orderId   String
  sender    String
  body      String
  readAt    DateTime?
  createdAt DateTime  @default(now())

  order Order @relation(fields: [orderId], references: [id], onDelete: Cascade)
}

model EventLog {
  id        String   @id @default(cuid())
  orderId   String
  event     String
  actor     String
  meta      String   @default("")
  createdAt DateTime @default(now())

  order Order @relation(fields: [orderId], references: [id], onDelete: Cascade)
}

model Invoice {
  id            String        @id @default(cuid())
  invoiceNumber String        @unique
  clientName    String
  clientEmail   String
  items         String
  subtotal      Float
  tax           Float         @default(0)
  total         Float
  currency      String        @default("USD")
  status        InvoiceStatus @default(draft)
  dueDate       DateTime?
  notes         String        @default("")
  sentAt        DateTime?
  paidAt        DateTime?
  orderId       String?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  order Order? @relation(fields: [orderId], references: [id], onDelete: SetNull)
}

model Subscription {
  id              String             @id @default(cuid())
  clientName      String
  clientEmail     String
  plan            String
  amount          Float
  currency        String             @default("USD")
  billingCycle    String             @default("monthly")
  status          SubscriptionStatus @default(active)
  paypalSubId     String?            @unique
  nextBillingDate DateTime?
  cancelledAt     DateTime?
  notes           String             @default("")
  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt
}

model Lead {
  id        String   @id @default(cuid())
  name      String
  email     String
  phone     String?
  message   String
  createdAt DateTime @default(now())
}
